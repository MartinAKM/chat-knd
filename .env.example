# ── Oracle Database ────────────────────────────────────────────────────────
# DSN format: host:port/service_name  e.g. 192.168.1.10:1521/ORCL
# To find your service name: SELECT VALUE FROM V$PARAMETER WHERE NAME = 'service_names';
ORACLE_USER=your_oracle_user
ORACLE_PASSWORD=your_oracle_password
ORACLE_DSN=hostname:1521/service_name
ORACLE_CALLS_QUERY=SELECT TICKET_ID, CLIENT_NAME, CATEGORY, DESCRIPTION, SOLUTION FROM SUPPORT_TICKETS

# Optional: absolute path to Oracle Instant Client directory.
# Enables thick-mode connections — recommended for Oracle 12c.
# Leave blank to use thin mode (no Instant Client required).
ORACLE_CLIENT_PATH=

# ── ChromaDB ───────────────────────────────────────────────────────────────
CHROMA_PATH=chroma_data
CHROMA_COLLECTION=documents

# ── Ollama ─────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Embedding model — runs locally via sentence-transformers (~90 MB download on first use)
EMBED_MODEL=all-MiniLM-L6-v2

# LLM used by the chat interface
CHAT_MODEL=gemma4:31b-cloud

# LLM used to summarise support tickets during ingestion.
# Can be a smaller/faster model to speed up batch processing.
# Defaults to CHAT_MODEL when left blank.
SUMMARIZE_MODEL=

# ── Email (password reset) ─────────────────────────────────────────────────
# For Gmail: enable 2-Step Verification, then generate an App Password at
# myaccount.google.com/apppasswords — use that 16-char code as SMTP_PASSWORD.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM=your-gmail@gmail.com

# ── Server ─────────────────────────────────────────────────────────────────
VIEWER_PORT=8001
# Public URL of the app — used in password-reset links sent by email.
APP_URL=http://localhost:8001
